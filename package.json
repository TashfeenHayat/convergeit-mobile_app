{
  "name": "convergeit-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start --go",
    "start:clear": "expo start --go --clear",
    "start:lan": "expo start --go --lan",
    "start:tunnel": "expo start --go --tunnel --port 8082",
    "start:anon": "expo start --go --tunnel --port 8082",
    "android": "expo start --go --android",
    "ios": "expo start --go --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "export:android": "expo export --platform android",
    "export:ios": "expo export --platform ios",
    "sync:env": "node scripts/sync-env-from-web.mjs",
    "sync:lib": "node scripts/sync-lib-from-web.cjs",
    "sync:services": "node scripts/sync-services-from-web.cjs",
    "sync:api": "node scripts/sync-api-from-web.cjs",
    "sync:web": "npm run sync:env && npm run sync:api && npm run sync:lib",
    "doctor": "npx expo-doctor@latest",
    "ci": "npm run typecheck && npm run lint",
    "storybook": "node scripts/start-with-env.cjs STORYBOOK_ENABLED=1 -- --go --clear"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-navigation/drawer": "^7.13.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "expo": "~54.0.35",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-drawer-layout": "^4.2.8",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@storybook/addon-ondevice-actions": "^9.1.4",
    "@storybook/addon-ondevice-controls": "^9.1.4",
    "@storybook/react-native": "^9.1.4",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~10.0.0",
    "react-test-renderer": "19.1.0",
    "storybook": "^9.1.20",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "metro-config": "0.83.4"
  }
}
