# Copy to `.env` for local Expo (or sync from web frontend .env).
# Expo exposes only vars prefixed with EXPO_PUBLIC_.
#
# Production (matches converge_saas_frontend/.env):

EXPO_PUBLIC_API_BASE_URL=https://api.convergeit.app
EXPO_PUBLIC_CHAT_SOCKET_BASE_URL=https://api.convergeit.app
EXPO_PUBLIC_CHAT_SOCKET_NAMESPACE=/chat
EXPO_PUBLIC_WIDGET_EMBED_ORIGIN=http://localhost:3003
EXPO_PUBLIC_APP_URL=https://app.convergeit.app

# Optional notifications socket (falls back to API base when unset)
# EXPO_PUBLIC_NOTIFICATIONS_SOCKET_BASE_URL=https://api.convergeit.app
# EXPO_PUBLIC_NOTIFICATIONS_SOCKET_NAMESPACE=/notifications
